        "@type": "Question",
        "name": "Do Umrah taxi prices include tolls?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The Haramain Expressway tolls between Jeddah and Makkah and the Route 60 tolls between Makkah and Madinah are included in the quoted price. No extra amount is collected at the toll gate."
        }
      },
      {
        "@type": "Question",
        "name": "Is the Umrah taxi price per person or per vehicle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All prices are per vehicle, not per person. A family of five in an SUV pays the SUV rate — not five individual fares."
        }
      },
      {
        "@type": "Question",
        "name": "How much more does Umrah taxi cost during Ramadan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Prices increase by 20–25% during Ramadan and by 30–40% during the last 10 nights of Ramadan, reflecting verified seasonal demand increases among licensed operators in Saudi Arabia."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a cancellation fee for Umrah taxi booking?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cancellations made 48 or more hours before the scheduled pickup time incur no charge. Cancellations within 48 hours incur 50% of the quoted price. No-shows on the day are charged the full price."
        }
      }
